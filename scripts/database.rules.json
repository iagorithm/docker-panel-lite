{
  "rules": {
    ".read": false,
    ".write": false,
    "workspaces": {
      "$workspaceId": {
        ".write": false,
        "repositories": {
          ".read": "auth != null && (auth.token.admin === true || auth.token.workspaceId === $workspaceId)",
          ".indexOn": ["updatedAt", "alias"]
        },
        "deployments": {
          ".read": "auth != null && (auth.token.admin === true || auth.token.workspaceId === $workspaceId)",
          ".indexOn": ["createdAt", "status", "repositoryId"]
        },
        "agents": {
          ".read": false,
          ".indexOn": ["lastHeartbeat", "poolId", "ownerUid", "sharing"]
        },
        "credentials": {
          ".read": "auth != null && (auth.token.admin === true || auth.token.workspaceId === $workspaceId)"
        },
        "containers": {
          ".read": "auth != null && (auth.token.admin === true || auth.token.workspaceId === $workspaceId)"
        },
        "commandPresets": {
          ".read": "auth != null && (auth.token.admin === true || auth.token.workspaceId === $workspaceId)"
        },
        "app_logs": {
          ".read": false,
          ".write": false,
          ".indexOn": ["createdAt", "actorType", "actorId"]
        }
      }
    },
    "jobs": { ".read": false, ".write": false, ".indexOn": ["status", "leaseExpiresAt", "workspaceId"] },
    "queues": { ".read": false, ".write": false },
    "locks": { ".read": false, ".write": false },
    "secrets": { ".read": false, ".write": false }
  }
}
