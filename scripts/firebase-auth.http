@firebaseApiKey = AIzaSyA7OUzGy3vxo-iaCIA59bqwBOs1U1edhwY
@email = test@test.com
@password = 000000

### Authenticate with Firebase email and password
# Copy NEXT_PUBLIC_FIREBASE_API_KEY from .env into firebaseApiKey above.
POST https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key={{firebaseApiKey}}
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}",
  "returnSecureToken": true
}



### Verify the authenticated Firebase user
POST https://identitytoolkit.googleapis.com/v1/accounts:lookup?key={{firebaseApiKey}}
Content-Type: application/json

{
  "idToken": "{{firebaseIdToken}}"
}
