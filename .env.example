# Firebase client configuration (Firebase Console > Project settings > Web app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin service account encoded as one-line JSON. Never commit the value.
# FIREBASE_DATABASE_URL is optional when NEXT_PUBLIC_FIREBASE_DATABASE_URL is set.
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
FIREBASE_SERVICE_ACCOUNT_JSON={}
DEFAULT_WORKSPACE_ID=default
DEFAULT_USER_ROLE=admin

# CrewAI diagnostics agent used by the Vercel logs app.
OPENAI_API_KEY=
CREWAI_MODEL=openai/gpt-5-mini
GITHUB_TOKEN=
GITHUB_REPOSITORY=owner/repository
GITHUB_BASE_BRANCH=main
LOGS_AGENT_SECRET=
LOGS_AGENT_MAX_CONCURRENCY=2
LOGS_AGENT_PREVIEW_TTL_SECONDS=3600
LOGS_AGENT_MAX_CHANGED_FILES=3
LOGS_AGENT_MAX_PAYLOAD_BYTES=250000
LOGS_AGENT_LLM_TIMEOUT_SECONDS=180
LOGS_AGENT_LLM_RETRIES=2
LOGS_AGENT_MAX_ITERATIONS=12
LOGS_AGENT_EXECUTION_TIMEOUT_SECONDS=240
LOGS_AGENT_DATABASE_PATH=/data/logs-agent.db
# Local Compose uses http://logs-agent:8000. In Vercel set this to the public
# HTTPS URL of the independently deployed CrewAI service.
LOGS_AGENT_URL=http://logs-agent:8000

# Generate with: openssl rand -base64 32
CREDENTIAL_ENCRYPTION_KEY=

# Queue and worker topology
# ./run.sh run starts both the Python worker and the local Go worker.
WORKER_RUNTIME=python
WORKER_IMAGE=cjarn/docker-panel-lite-worker:py
WORKER_GO_IMAGE=cjarn/docker-panel-lite-worker:go
# Optional release name injected into Go worker heartbeats. Publications use
# the exact Git commit SHA when this is empty.
WORKER_VERSION=
WORKER_IMAGE_PLATFORMS=linux/amd64,linux/arm64
# Python images include these worker settings as fallback configuration and
# allow runtime overrides. Go compiles the selected values into its binary and
# intentionally ignores runtime environment variables.
WORKER_BAKE_CONFIG=true
QUEUE_SHARDS=16
WORKER_WORKSPACE_ID=default
WORKER_POOL=default
WORKER_TOKEN=
WORKER_SHARDS=
WORKER_MAX_CONCURRENCY=2
WORKER_LEASE_SECONDS=90
WORKER_POLL_SECONDS=5

# Optional Go worker overrides. It uses ./volume/data/worker-go and ./volume/repos/worker-go locally.
# Leave WORKER_GO_LABEL empty to let the Go worker choose an available name.
WORKER_GO_POOL=go-local
WORKER_GO_ID=
WORKER_GO_TOKEN=
WORKER_GO_LABEL=

# Public ports
NEXT_PORT=3000
HTTP_PORT=80
HTTPS_PORT=443

# openssl rand -hex 32
